# LernHive Hetzner deploy target — production server.
#
# This file is sourced by playbooks/deploy.sh when invoked with --target=hetzner.
# Values here are PLACEHOLDERS — they will be finalised once the Hetzner server
# is provisioned via playbooks/hetzner-setup.sh (Moodle docker-compose stack name
# "lernhive" by convention).
#
# To adjust: SSH into the server, run `docker ps` to find the actual webserver
# container name and `docker exec <container> ls /var/www` to confirm Moodle path.

# Docker container running Moodle on the Hetzner host.
# Expected convention: docker-compose stack "lernhive", service "webserver".
CONTAINER="lernhive-webserver-1"

# Path to Moodle's docroot inside the container.
# Moodle 5.x uses the new public/ layout — plugins, config.php and admin/
# all live under /var/www/html/public. For Moodle 4.x (LTS) switch this to
# /var/www/html (both MOODLE_ROOT and MOODLE_CLI_ROOT).
MOODLE_ROOT="/var/www/html/public"

# Path from which admin/cli/*.php is executed. In 5.x this is the same as
# MOODLE_ROOT (public/), in 4.x it's the plain html/ root.
MOODLE_CLI_ROOT="/var/www/html/public"

# Linux user inside the container that owns Moodle files and runs PHP CLI.
MOODLE_USER="www-data"
