# LernHive local deploy target — OrbStack / docker-compose "demo" stack.
#
# This file is sourced by playbooks/deploy.sh when invoked with --target=local.
# Values reflect Johannes' local dev setup (Moodle 5.2beta on OrbStack).

# Docker container running Moodle (docker-compose service "webserver" of stack "demo").
CONTAINER="demo-webserver-1"

# Path to Moodle's public docroot inside the container (where plugins are installed).
# For Moodle 5.x with the "public/" subfolder layout used by moodle-docker + demo stack.
MOODLE_ROOT="/var/www/site/moodle/public"

# Path from which admin/cli/upgrade.php and purge_caches.php are executed.
# On Moodle 5.x this is usually the same as MOODLE_ROOT's parent.
MOODLE_CLI_ROOT="/var/www/site/moodle"

# Linux user inside the container that owns Moodle files and runs PHP CLI.
MOODLE_USER="www-data"
