# Hetzner test target config.
#
# Consumed by playbooks/test.sh. The Hetzner stack runs Moodle 5.1 with
# the Moodle 5.x public/ split:
#   /var/www/html/               MOODLE_REPO_ROOT
#     composer.json, composer.lock
#     config.php
#     vendor/bin/{phpunit,behat}
#     phpunit.xml                <- generated by admin/tool/phpunit init
#     public/                    MOODLE_CLI_ROOT
#       admin/tool/phpunit/cli/  <- init + util CLI scripts
#       admin/tool/behat/cli/
#       lib/ mod/ local/ ...     <- actual Moodle code
#
# The two roots are needed separately because:
#   - PHPUnit/Behat CLI helper scripts (init.php, util.php) live under
#     public/, so we cd into MOODLE_CLI_ROOT to invoke them.
#   - The generated phpunit.xml lives at MOODLE_REPO_ROOT (next to
#     vendor/ and composer.json), and the phpunit binary must be run
#     from that directory so that relative paths inside phpunit.xml
#     resolve correctly.
#
# On a classic (non-split) Moodle install you can omit MOODLE_REPO_ROOT
# in sibling env files — test.sh falls back to MOODLE_CLI_ROOT.
#
# Production data is never touched: PHPUnit and Behat run against
# their own DB prefixes (phpu_ / beh_) and their own datarooots
# configured in config.php.

CONTAINER="lernhive-webserver-1"
MOODLE_REPO_ROOT="/var/www/html"
MOODLE_CLI_ROOT="/var/www/html/public"
MOODLE_USER="www-data"

# Composer-installed vendor binaries. vendor/ sits at the Moodle repo
# root (MOODLE_REPO_ROOT) because composer.json lives there. These
# paths are expressed as literals so they stay intact even if future
# changes reshuffle the *_ROOT values.
PHPUNIT_BIN="$MOODLE_REPO_ROOT/vendor/bin/phpunit"
BEHAT_BIN="$MOODLE_REPO_ROOT/vendor/bin/behat"

# PHP memory limit for the PHPUnit run. The default Moodle PHPUnit
# setup is happy with 256M today, but component count is growing, so
# we bump to 512M defensively. Raise if `Allowed memory size of N
# bytes exhausted` shows up in CI.
PHPUNIT_MEM="512M"
