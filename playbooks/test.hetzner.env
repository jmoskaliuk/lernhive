# Hetzner test target config.
#
# Consumed by playbooks/test.sh. The container layout mirrors
# deploy.hetzner.env — Moodle lives under /var/www/html with the
# Moodle 5.x public/ split, CLI scripts run from the repo root.
#
# Production data is never touched: PHPUnit and Behat run against
# their own DB prefixes (phpunit_ / bht_) and their own datarooots
# configured in config.php.

CONTAINER="lernhive-webserver-1"
MOODLE_CLI_ROOT="/var/www/html"
MOODLE_USER="www-data"

# Composer-installed vendor binaries. Overridable if the project ever
# ships a different phpunit/behat location.
PHPUNIT_BIN="/var/www/html/vendor/bin/phpunit"
BEHAT_BIN="/var/www/html/vendor/bin/behat"

# PHP memory limit for the PHPUnit run. The default Moodle PHPUnit
# setup is happy with 256M today, but component count is growing, so
# we bump to 512M defensively. Raise if `Allowed memory size of N
# bytes exhausted` shows up in CI.
PHPUNIT_MEM="512M"
