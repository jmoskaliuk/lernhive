# Hetzner test target config.
#
# Consumed by playbooks/test.sh. The Hetzner stack runs Moodle 5.1 with
# the Moodle 5.x public/ split (code under /var/www/html/public/, with
# config.php and composer.json at /var/www/html/). The CLI scripts
# (admin/tool/phpunit/cli/*, admin/tool/behat/cli/*) therefore live
# under public/ and MOODLE_CLI_ROOT must point there so that the test
# runner can `cd $MOODLE_CLI_ROOT && php admin/tool/phpunit/cli/...`.
#
# vendor/ stays at the Moodle repo root (next to composer.json), so
# PHPUNIT_BIN / BEHAT_BIN point one level above MOODLE_CLI_ROOT.
#
# Production data is never touched: PHPUnit and Behat run against
# their own DB prefixes (phpu_ / beh_) and their own datarooots
# configured in config.php.

CONTAINER="lernhive-webserver-1"
MOODLE_CLI_ROOT="/var/www/html/public"
MOODLE_USER="www-data"

# Composer-installed vendor binaries. vendor/ sits at the Moodle repo
# root (one level above MOODLE_CLI_ROOT) because composer.json lives
# there. Overridable if the project ever ships a different layout.
PHPUNIT_BIN="/var/www/html/vendor/bin/phpunit"
BEHAT_BIN="/var/www/html/vendor/bin/behat"

# PHP memory limit for the PHPUnit run. The default Moodle PHPUnit
# setup is happy with 256M today, but component count is growing, so
# we bump to 512M defensively. Raise if `Allowed memory size of N
# bytes exhausted` shows up in CI.
PHPUNIT_MEM="512M"
