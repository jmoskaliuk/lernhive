<article class="lernhive-snack-step">
    <div class="lernhive-snack-step__icon" aria-hidden="true">
        {{#isinput}}
            <svg viewBox="0 0 24 24" focusable="false">
                <circle cx="12" cy="12" r="9"></circle>
                <path d="m10 8 6 4-6 4Z"></path>
            </svg>
        {{/isinput}}
        {{#istask}}
            <svg viewBox="0 0 24 24" focusable="false">
                <path d="M12 20h9"></path>
                <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"></path>
            </svg>
        {{/istask}}
        {{#iswrapup}}
            <svg viewBox="0 0 24 24" focusable="false">
                <path d="M4 22V4"></path>
                <path d="M4 4h11l-1.5 3L15 10H4"></path>
            </svg>
        {{/iswrapup}}
    </div>

    <div class="lernhive-snack-step__main">
        <h3 class="lernhive-snack-step__title">{{ title }}</h3>
        {{#summary}}
            <p class="lernhive-snack-step__summary">{{ summary }}</p>
        {{/summary}}
        <div class="lernhive-snack-step__meta">
            {{#type}}
                <span class="lernhive-snack-step__type">{{ type }}</span>
            {{/type}}
            {{#meta}}
                <span>{{ meta }}</span>
            {{/meta}}
        </div>
    </div>

    {{#actionlabel}}
        <a class="lernhive-snack-step__cta" href="{{ actionurl }}">
            <span>{{ actionlabel }}</span>
        </a>
    {{/actionlabel}}
</article>
