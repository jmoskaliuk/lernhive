{{!
    @template local_lernhive_copy/wizard_page

    Copy wizard entry page.

    Context:
    {
        "istemplate": false,
        "hasform": true,
        "formhtml": "<form>...</form>",
        "showmodetoggle": true,
        "simpleurl": "/local/lernhive_copy/index.php",
        "experturl": "/local/lernhive_copy/index.php?mode=expert",
        "modeissimple": true,
        "modeisexpert": false,
        "hasreturnurl": true,
        "returnurl": "/local/lernhive_contenthub/index.php",
        "showtemplatelist": false,
        "templateentries": [],
        "heading": "Copy a course",
        "intro": "Pick an existing course.",
        "mode_simple": "Simple",
        "mode_simple_desc": "Copy structure only.",
        "mode_expert": "Expert",
        "mode_expert_desc": "Full backup/restore flow.",
        "cta_simple": "Start simple copy",
        "cta_expert": "Open expert mode",
        "notice": "Under construction."
    }
}}
{{! ── Zone A: sticky header ─────────────────────────────────────────────── }}
<div class="lh-plugin-header">
    <div class="lh-plugin-header__row">
        {{#hasreturnurl}}
            <a class="lh-plugin-header__nav-btn" href="{{returnurl}}">
                <i class="fa fa-arrow-left" aria-hidden="true"></i>
                {{returnlabel}}
            </a>
        {{/hasreturnurl}}

        <div class="lh-plugin-header__title-block">
            <div class="lh-plugin-header__name">
                {{#str}} pluginname, local_lernhive_copy {{/str}}
                <span class="lh-plugin-header__sep" aria-hidden="true">|</span>
                <span class="lh-plugin-header__tagline">{{heading}}</span>
            </div>
            <p class="lh-plugin-header__subtitle">{{intro}}</p>
            <div class="lh-plugin-header__tags" aria-label="{{#str}} tags {{/str}}">
                <span class="lh-plugin-tag lh-plugin-tag--type">
                    <i class="fa fa-copy" aria-hidden="true"></i>
                    {{#str}} shell_tag_copy, local_lernhive_copy {{/str}}
                </span>
                {{#istemplate}}
                    <span class="lh-plugin-tag lh-plugin-tag--active">
                        <i class="fa fa-th-large" aria-hidden="true"></i>
                        {{#str}} shell_tag_template, local_lernhive_copy {{/str}}
                    </span>
                {{/istemplate}}
                {{^istemplate}}
                    <span class="lh-plugin-tag lh-plugin-tag--active">
                        <i class="fa fa-graduation-cap" aria-hidden="true"></i>
                        {{#str}} shell_tag_course, local_lernhive_copy {{/str}}
                    </span>
                {{/istemplate}}
            </div>
        </div>
    </div>
</div>

{{! ── Zone B: hint + mode controls ──────────────────────────────────────── }}
<div class="lh-plugin-infobar">
    <div class="lh-plugin-infobar__stats">
        <span class="lh-plugin-infobar__stat">
            <i class="fa fa-info-circle" aria-hidden="true"></i>
            {{#str}} infobar_hint, local_lernhive_copy {{/str}}
        </span>
        {{#active_template}}
            <span class="lh-plugin-infobar__stat">
                <i class="fa fa-file-text-o" aria-hidden="true"></i>
                <strong>{{active_template_label}}</strong>
                {{active_template}}
            </span>
        {{/active_template}}
    </div>
    {{#showmodetoggle}}
        <nav class="lh-copy-shell-actions" aria-label="{{#str}} pluginname, local_lernhive_copy {{/str}}">
            <a href="{{simpleurl}}" class="lh-btn-outline lh-copy-shell-action{{#modeissimple}} lh-copy-shell-action--active{{/modeissimple}}">
                <i class="fa fa-check-circle-o" aria-hidden="true"></i>
                {{mode_simple}}
            </a>
            <a href="{{experturl}}" class="lh-btn-outline lh-copy-shell-action{{#modeisexpert}} lh-copy-shell-action--active{{/modeisexpert}}">
                <i class="fa fa-sliders" aria-hidden="true"></i>
                {{mode_expert}}
            </a>
        </nav>
    {{/showmodetoggle}}
</div>

{{! ── Content ────────────────────────────────────────────────────────────── }}
<div class="lh-plugin-content-area">
    <div class="lh-copy-container{{#istemplate}} lh-copy-container--template{{/istemplate}}">
        {{#template_warning}}
            <div class="lh-copy-note lh-copy-note--warning" role="alert">
                {{template_warning}}
            </div>
        {{/template_warning}}

        {{#hasform}}
            <div class="lh-copy-form">
                {{{formhtml}}}
            </div>
        {{/hasform}}

        {{#showtemplatelist}}
            <section class="lh-copy-template-list" aria-label="{{template_heading}}">
                <h3 class="lh-copy-template-title">{{template_heading}}</h3>

                {{#templateempty}}
                    <div class="lh-copy-notice" role="status">
                        {{template_empty}}
                    </div>
                {{/templateempty}}

                {{^templateempty}}
                    <ul class="lh-copy-template-grid" role="list">
                        {{#templateentries}}
                            <li class="lh-copy-template-card{{#isactive}} lh-copy-template-card--active{{/isactive}}" role="listitem" data-template-id="{{id}}">
                                <h4 class="lh-copy-template-card-title">{{title}}</h4>
                                <p class="lh-copy-template-card-desc">{{description}}</p>

                                <dl class="lh-copy-template-meta">
                                    <dt>{{template_meta_version}}</dt>
                                    <dd>{{version}}</dd>
                                    <dt>{{template_meta_updated}}</dt>
                                    <dd>{{updated}}</dd>
                                    <dt>{{template_meta_language}}</dt>
                                    <dd>{{language}}</dd>
                                </dl>

                                <div class="lh-copy-template-card-actions">
                                    {{#hasaction}}
                                        <a href="{{actionurl}}" class="lh-btn-open">
                                            <i class="fa fa-arrow-right" aria-hidden="true"></i>
                                            {{template_select}}
                                        </a>
                                    {{/hasaction}}
                                    {{^hasaction}}
                                        <button type="button" class="lh-btn-ghost lh-copy-btn-disabled" disabled aria-disabled="true">
                                            <i class="fa fa-lock" aria-hidden="true"></i>
                                            {{template_unavailable}}
                                        </button>
                                    {{/hasaction}}
                                    <span class="lh-copy-template-card-actions-gap"></span>
                                    <button type="button"
                                            class="lh-btn-action"
                                            aria-label="{{#str}} template_info, local_lernhive_copy {{/str}}"
                                            title="{{#str}} template_info, local_lernhive_copy {{/str}}">
                                        <i class="fa fa-info" aria-hidden="true"></i>
                                    </button>
                                </div>

                                {{^hasaction}}
                                    <p class="lh-copy-template-hint">{{template_unavailable_hint}}</p>
                                {{/hasaction}}
                            </li>
                        {{/templateentries}}
                    </ul>
                {{/templateempty}}
            </section>
        {{/showtemplatelist}}

        {{#showstub}}
            <div class="lh-copy-modes" role="list">
                <div class="lh-copy-mode lh-copy-mode--simple" role="listitem">
                    <h3 class="lh-copy-mode-title">{{mode_simple}}</h3>
                    <p class="lh-copy-mode-desc">{{mode_simple_desc}}</p>
                    <div class="lh-copy-mode-actions">
                        <button type="button" class="lh-btn-open lh-copy-btn-disabled" disabled aria-disabled="true">
                            <i class="fa fa-arrow-right" aria-hidden="true"></i>
                            {{cta_simple}}
                        </button>
                        <span class="lh-copy-mode-actions-gap"></span>
                        <button type="button" class="lh-btn-action" aria-label="{{mode_simple}}" title="{{mode_simple}}">
                            <i class="fa fa-info" aria-hidden="true"></i>
                        </button>
                    </div>
                </div>
                <div class="lh-copy-mode lh-copy-mode--expert" role="listitem">
                    <h3 class="lh-copy-mode-title">{{mode_expert}}</h3>
                    <p class="lh-copy-mode-desc">{{mode_expert_desc}}</p>
                    <div class="lh-copy-mode-actions">
                        <button type="button" class="lh-btn-ghost lh-copy-btn-disabled" disabled aria-disabled="true">
                            <i class="fa fa-lock" aria-hidden="true"></i>
                            {{cta_expert}}
                        </button>
                        <span class="lh-copy-mode-actions-gap"></span>
                        <button type="button" class="lh-btn-action" aria-label="{{mode_expert}}" title="{{mode_expert}}">
                            <i class="fa fa-info" aria-hidden="true"></i>
                        </button>
                    </div>
                </div>
            </div>

            <div class="lh-copy-notice" role="note">
                {{notice}}
            </div>
        {{/showstub}}
    </div>
</div>
