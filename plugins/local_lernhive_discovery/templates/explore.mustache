<section class="local-lernhive-discovery">
    <h1>{{title}}</h1>
    <p>{{summary}}</p>

    {{#sections}}
        <article class="local-lernhive-discovery__section">
            <h2>{{title}}</h2>
            <p>{{description}}</p>
            {{#cards}}
                <div class="local-lernhive-discovery__card">
                    <strong>{{title}}</strong>
                    <p>{{summary}}</p>
                    <p>{{meta}}</p>
                </div>
            {{/cards}}
        </article>
    {{/sections}}
</section>
