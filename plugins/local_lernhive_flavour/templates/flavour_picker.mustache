{{!
    @template local_lernhive_flavour/flavour_picker

    Flavour setup picker: one card per registered flavour profile.

    Context:
    {
        "heading": "Flavour Setup",
        "intro": "Choose a flavour to apply its defaults.",
        "activelabel": "School",
        "activekey": "school",
        "cards": [
            {
                "key": "school",
                "label": "School",
                "description": "Traditional LMS for schools.",
                "icon": "🏫",
                "isactive": true,
                "experimental": false,
                "overrides": false,
                "sesskey": "abcd1234"
            }
        ]
    }
}}
<div class="lh-flavour-container">
    <div class="lh-flavour-intro">
        <h2>{{heading}}</h2>
        <p>{{intro}}</p>
    </div>

    <div class="lh-flavour-cards" role="list">
        {{#cards}}
            <div class="lh-flavour-card{{#isactive}} lh-flavour-card--active{{/isactive}}{{#experimental}} lh-flavour-card--experimental{{/experimental}}" role="listitem">
                {{#isactive}}
                    <span class="lh-flavour-badge lh-flavour-badge--active">{{#str}}badge_active, local_lernhive_flavour{{/str}}</span>
                {{/isactive}}
                {{#experimental}}
                    <span class="lh-flavour-badge lh-flavour-badge--experimental">{{#str}}badge_experimental, local_lernhive_flavour{{/str}}</span>
                {{/experimental}}

                <div class="lh-flavour-icon" aria-hidden="true">{{{icon}}}</div>
                <h3 class="lh-flavour-title">{{label}}</h3>
                <p class="lh-flavour-desc">{{description}}</p>

                <form method="post" action="admin_flavour.php" class="lh-flavour-form">
                    <input type="hidden" name="action" value="{{#overrides}}confirm{{/overrides}}{{^overrides}}apply{{/overrides}}">
                    <input type="hidden" name="flavour" value="{{key}}">
                    <input type="hidden" name="sesskey" value="{{sesskey}}">
                    <button
                        type="submit"
                        class="btn {{#isactive}}btn-secondary disabled{{/isactive}}{{^isactive}}btn-primary{{/isactive}}"
                        {{#isactive}}disabled aria-disabled="true"{{/isactive}}
                    >
                        {{#isactive}}{{#str}}btn_current, local_lernhive_flavour{{/str}}{{/isactive}}
                        {{^isactive}}{{#str}}btn_apply, local_lernhive_flavour{{/str}}{{/isactive}}
                    </button>
                </form>
            </div>
        {{/cards}}
    </div>

    <div class="lh-flavour-current">
        {{#str}}current_flavour, local_lernhive_flavour, {{activelabel}}{{/str}}
    </div>
</div>
