{{!
    @template local_lernhive_library/catalog_page

    Library catalog page — empty state or a grid of entries.

    Context:
    {
        "heading": "LernHive Library",
        "intro": "Ready-to-use courses curated by eLeDia.",
        "empty": true,
        "emptymsg": "The library catalog is empty.",
        "entries": [
            {
                "id": "demo-biology-101",
                "title": "Biology 101",
                "description": "A short demo course.",
                "version": "1.0.0",
                "updated": "1 January 2026",
                "language": "EN"
            }
        ],
        "labels": {
            "version": "Version",
            "updated": "Last updated",
            "language": "Language",
            "import": "Import"
        }
    }
}}
<div class="lh-library-container">
    <div class="lh-library-intro">
        <h2>{{heading}}</h2>
        <p>{{intro}}</p>
    </div>

    {{#empty}}
        <div class="lh-library-empty" role="status">
            {{emptymsg}}
        </div>
    {{/empty}}

    {{^empty}}
        <ul class="lh-library-grid" role="list">
            {{#entries}}
                <li class="lh-library-card" role="listitem" data-entry-id="{{id}}">
                    <h3 class="lh-library-card-title">{{title}}</h3>
                    <p class="lh-library-card-desc">{{description}}</p>

                    <dl class="lh-library-card-meta">
                        <dt>{{labels.version}}</dt>
                        <dd>{{version}}</dd>
                        <dt>{{labels.updated}}</dt>
                        <dd>{{updated}}</dd>
                        <dt>{{labels.language}}</dt>
                        <dd>{{language}}</dd>
                    </dl>

                    <button type="button" class="btn btn-primary disabled" disabled aria-disabled="true">
                        {{labels.import}}
                    </button>
                </li>
            {{/entries}}
        </ul>
    {{/empty}}
</div>
