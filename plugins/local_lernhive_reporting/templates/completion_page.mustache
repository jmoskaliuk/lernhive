{{!
    @template local_lernhive_reporting/completion_page
}}

<a class="btn btn-link mb-3 px-0" href="{{backurl}}">{{#str}} back_to_dashboard, local_lernhive_reporting {{/str}}</a>

{{#hascourses}}
<div class="card mb-4">
    <div class="card-body">
        <h2 class="h5 mb-3">{{#str}} tile_completion_title, local_lernhive_reporting {{/str}}</h2>
        <form method="get" action="{{selecturl}}" class="form-inline">
            <label class="mr-2" for="id_courseid">{{#str}} course_label, local_lernhive_reporting {{/str}}</label>
            <select id="id_courseid" name="courseid" class="custom-select mr-2">
                {{#courseoptions}}
                <option value="{{value}}"{{#selected}} selected{{/selected}}>{{label}}</option>
                {{/courseoptions}}
            </select>
            <button type="submit" class="btn btn-primary">{{#str}} filter_apply, local_lernhive_reporting {{/str}}</button>
        </form>
    </div>
</div>

<div class="row">
    <div class="col-md-3 mb-3">
        <div class="card h-100"><div class="card-body"><div class="h6 text-muted">{{#str}} participants_label, local_lernhive_reporting {{/str}}</div><div class="h3">{{selectedparticipants}}</div></div></div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card h-100"><div class="card-body"><div class="h6 text-muted">{{#str}} completed_label, local_lernhive_reporting {{/str}}</div><div class="h3">{{selectedcompleted}}</div></div></div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card h-100"><div class="card-body"><div class="h6 text-muted">{{#str}} pending_label, local_lernhive_reporting {{/str}}</div><div class="h3">{{selectedpending}}</div></div></div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card h-100"><div class="card-body"><div class="h6 text-muted">{{#str}} completion_rate_label, local_lernhive_reporting {{/str}}</div><div class="h3">{{selectedcompletionratetext}}</div></div></div>
    </div>
</div>

{{#completionisempty}}
<div class="alert alert-info" role="status">{{#str}} empty_completion_no_participants, local_lernhive_reporting {{/str}}</div>
{{/completionisempty}}
{{#completionnotstarted}}
<div class="alert alert-info" role="status">{{#str}} empty_completion_no_completions, local_lernhive_reporting {{/str}}</div>
{{/completionnotstarted}}

<div class="card">
    <div class="card-body">
        <h3 class="h6 text-muted mb-3">{{#str}} drilldown_completion, local_lernhive_reporting {{/str}}</h3>
        {{#hasrows}}
        <div class="table-responsive">
            <table class="table table-sm table-striped mb-0">
                <thead>
                    <tr>
                        <th>{{#str}} course_label, local_lernhive_reporting {{/str}}</th>
                        <th class="text-right">{{#str}} participants_label, local_lernhive_reporting {{/str}}</th>
                        <th class="text-right">{{#str}} completed_label, local_lernhive_reporting {{/str}}</th>
                        <th class="text-right">{{#str}} completion_rate_label, local_lernhive_reporting {{/str}}</th>
                    </tr>
                </thead>
                <tbody>
                    {{#rows}}
                    <tr>
                        <td><a href="{{courseurl}}">{{coursename}}</a></td>
                        <td class="text-right">{{participants}}</td>
                        <td class="text-right">{{completed}}</td>
                        <td class="text-right">{{completiontext}}</td>
                    </tr>
                    {{/rows}}
                </tbody>
            </table>
        </div>
        {{/hasrows}}
        {{^hasrows}}
        <p class="text-muted mb-0">{{#str}} no_completion_rows_notice, local_lernhive_reporting {{/str}}</p>
        {{/hasrows}}
    </div>
</div>
{{/hascourses}}

{{^hascourses}}
<div class="alert alert-info" role="status">{{#str}} no_courses_notice, local_lernhive_reporting {{/str}}</div>
{{/hascourses}}
