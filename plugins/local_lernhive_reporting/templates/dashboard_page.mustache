{{!
    @template local_lernhive_reporting/dashboard_page

    Context fields (excerpt):
    {
        "hastiles": true,
        "courseoptions": [{"value": 5, "label": "Course A", "selected": true}],
        "usercount": 42,
        "toppopularcoursename": "Course A",
        "toppopularcourseusers": 42,
        "selectedcompletionratetext": "55%",
        "popularrows": [],
        "completionrows": []
    }
}}

<div class="container-fluid px-0">
    {{#hascourses}}
    <div class="card mb-4">
        <div class="card-body">
            <h2 class="h5 mb-3">{{#str}} filter_heading, local_lernhive_reporting {{/str}}</h2>
            <form method="get" action="{{selecturl}}" class="form-inline">
                <label class="mr-2" for="id_courseid">{{#str}} course_label, local_lernhive_reporting {{/str}}</label>
                <select id="id_courseid" name="courseid" class="custom-select mr-2">
                    {{#courseoptions}}
                    <option value="{{value}}"{{#selected}} selected{{/selected}}>{{label}}</option>
                    {{/courseoptions}}
                </select>
                <button type="submit" class="btn btn-primary">{{#str}} filter_apply, local_lernhive_reporting {{/str}}</button>
            </form>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h3 class="h6 text-muted mb-2">{{#str}} tile_users_title, local_lernhive_reporting {{/str}}</h3>
                    <div class="display-4 mb-2">{{usercount}}</div>
                    <p class="mb-2">{{selectedcoursename}}</p>
                    {{#hasselectedcourse}}
                    <a class="btn btn-link px-0" href="{{usersdrilldownurl}}">
                        {{#str}} open_users_report, local_lernhive_reporting {{/str}}
                    </a>
                    {{/hasselectedcourse}}
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h3 class="h6 text-muted mb-2">{{#str}} tile_popular_title, local_lernhive_reporting {{/str}}</h3>
                    <div class="h4 mb-2">{{toppopularcoursename}}</div>
                    <p class="mb-2">{{toppopularcourseusers}} {{#str}} participants_label, local_lernhive_reporting {{/str}}</p>
                    <a class="btn btn-link px-0" href="{{populardrilldownurl}}">
                        {{#str}} open_popular_report, local_lernhive_reporting {{/str}}
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h3 class="h6 text-muted mb-2">{{#str}} tile_completion_title, local_lernhive_reporting {{/str}}</h3>
                    <div class="display-4 mb-2">{{selectedcompletionratetext}}</div>
                    <p class="mb-2">
                        {{selectedcompleted}} {{#str}} completed_label, local_lernhive_reporting {{/str}}
                        / {{selectedparticipants}} {{#str}} participants_label, local_lernhive_reporting {{/str}}
                    </p>
                    {{#hasselectedcourse}}
                    <a class="btn btn-link px-0" href="{{completiondrilldownurl}}">
                        {{#str}} open_completion_report, local_lernhive_reporting {{/str}}
                    </a>
                    {{/hasselectedcourse}}
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-2">
        <div class="col-lg-6 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <h2 class="h5 mb-3">{{#str}} drilldown_popular, local_lernhive_reporting {{/str}}</h2>
                    {{#haspopularrows}}
                    <div class="table-responsive">
                        <table class="table table-sm table-striped mb-0">
                            <thead>
                                <tr>
                                    <th>{{#str}} course_label, local_lernhive_reporting {{/str}}</th>
                                    <th class="text-right">{{#str}} participants_label, local_lernhive_reporting {{/str}}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#popularrows}}
                                <tr>
                                    <td><a href="{{courseurl}}">{{coursename}}</a></td>
                                    <td class="text-right">{{usercount}}</td>
                                </tr>
                                {{/popularrows}}
                            </tbody>
                        </table>
                    </div>
                    {{/haspopularrows}}
                    {{^haspopularrows}}
                    <p class="text-muted mb-0">{{#str}} no_data, local_lernhive_reporting {{/str}}</p>
                    {{/haspopularrows}}
                </div>
            </div>
        </div>

        <div class="col-lg-6 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <h2 class="h5 mb-3">{{#str}} drilldown_completion, local_lernhive_reporting {{/str}}</h2>
                    {{#hascompletionrows}}
                    <div class="table-responsive">
                        <table class="table table-sm table-striped mb-0">
                            <thead>
                                <tr>
                                    <th>{{#str}} course_label, local_lernhive_reporting {{/str}}</th>
                                    <th class="text-right">{{#str}} participants_label, local_lernhive_reporting {{/str}}</th>
                                    <th class="text-right">{{#str}} completed_label, local_lernhive_reporting {{/str}}</th>
                                    <th class="text-right">{{#str}} completion_rate_label, local_lernhive_reporting {{/str}}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#completionrows}}
                                <tr>
                                    <td><a href="{{courseurl}}">{{coursename}}</a></td>
                                    <td class="text-right">{{participants}}</td>
                                    <td class="text-right">{{completed}}</td>
                                    <td class="text-right">{{completiontext}}</td>
                                </tr>
                                {{/completionrows}}
                            </tbody>
                        </table>
                    </div>
                    {{/hascompletionrows}}
                    {{^hascompletionrows}}
                    <p class="text-muted mb-0">{{#str}} no_data, local_lernhive_reporting {{/str}}</p>
                    {{/hascompletionrows}}
                </div>
            </div>
        </div>
    </div>
    {{/hascourses}}

    {{^hascourses}}
    <div class="alert alert-info" role="status">
        {{#str}} no_courses_notice, local_lernhive_reporting {{/str}}
    </div>
    {{/hascourses}}
</div>
