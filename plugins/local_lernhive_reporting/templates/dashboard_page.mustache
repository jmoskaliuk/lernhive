{{!
    @template local_lernhive_reporting/dashboard_page

    Context fields (excerpt):
    {
        "hastiles": true,
        "courseoptions": [{"value": 5, "label": "Course A", "selected": true}],
        "usercount": 42,
        "toppopularcoursename": "Course A",
        "toppopularcourseusers": 42,
        "selectedcompletionratetext": "55%",
        "popularrows": [],
        "completionrows": []
    }
}}

<div class="lh-reporting-page">
    <div class="lh-plugin-header">
        <div class="lh-plugin-header__row">
            <div class="lh-plugin-header__title-block">
                <div class="lh-plugin-header__name">
                    {{#str}} pluginname, local_lernhive_reporting {{/str}}
                    <span class="lh-plugin-header__sep">|</span>
                    <span class="lh-plugin-header__tagline">{{#str}} dashboard_tagline, local_lernhive_reporting {{/str}}</span>
                </div>
                <p class="lh-plugin-header__subtitle">{{#str}} dashboard_subtitle, local_lernhive_reporting {{/str}}</p>
                <div class="lh-plugin-header__tags">
                    <span class="lh-plugin-tag lh-plugin-tag--active">{{#str}} tag_release1, local_lernhive_reporting {{/str}}</span>
                    <span class="lh-plugin-tag lh-plugin-tag--type">{{#str}} tag_moodlebased, local_lernhive_reporting {{/str}}</span>
                </div>
            </div>
        </div>
    </div>

    {{#hascourses}}
    <div class="lh-plugin-infobar">
        <div class="lh-plugin-infobar__stats">
            <div class="lh-plugin-infobar__stat">
                <i class="fa fa-book" aria-hidden="true"></i>
                <strong>{{selectedcoursename}}</strong>
            </div>
            <div class="lh-plugin-infobar__stat">
                <i class="fa fa-users" aria-hidden="true"></i>
                <strong>{{usercount}}</strong>
                {{#str}} participants_label, local_lernhive_reporting {{/str}}
            </div>
            <div class="lh-plugin-infobar__stat">
                <i class="fa fa-check-circle" aria-hidden="true"></i>
                <strong>{{selectedcompletionratetext}}</strong>
                {{#str}} completion_rate_label, local_lernhive_reporting {{/str}}
            </div>
        </div>
        {{#hasselectedcourse}}
        <a class="lh-plugin-infobar__cta" href="{{completiondrilldownurl}}">
            <i class="fa fa-arrow-right" aria-hidden="true"></i>
            {{#str}} open_completion_report, local_lernhive_reporting {{/str}}
        </a>
        {{/hasselectedcourse}}
    </div>
    {{/hascourses}}

    <div class="lh-plugin-content-area">
        {{#hascourses}}
        <div class="lh-plugin-card lh-reporting-filter-card">
            <div class="lh-plugin-card__top">
                <span class="lh-plugin-card__icon lh-plugin-card__icon--generic" aria-hidden="true">
                    <i class="fa fa-filter"></i>
                </span>
                <div class="lh-plugin-card__meta">
                    <div class="lh-plugin-card__kicker">{{#str}} filter_heading, local_lernhive_reporting {{/str}}</div>
                    <div class="lh-plugin-card__title">{{#str}} course_label, local_lernhive_reporting {{/str}}</div>
                    <div class="lh-plugin-card__sub">{{#str}} filter_helptext, local_lernhive_reporting {{/str}}</div>
                </div>
            </div>
            <div class="lh-plugin-card__body">
                <form method="get" action="{{selecturl}}" class="lh-reporting-filter-form">
                    <div class="lh-reporting-field">
                        <label class="lh-reporting-label" for="id_courseid">{{#str}} course_label, local_lernhive_reporting {{/str}}</label>
                        <select id="id_courseid" name="courseid" class="lh-reporting-select">
                            {{#courseoptions}}
                            <option value="{{value}}"{{#selected}} selected{{/selected}}>{{label}}</option>
                            {{/courseoptions}}
                        </select>
                    </div>
                    <button type="submit" class="lh-btn lh-btn--accent btn btn-primary">{{#str}} filter_apply, local_lernhive_reporting {{/str}}</button>
                </form>
            </div>
        </div>

        <div class="lh-plugin-grid lh-plugin-grid--cols-3 lh-reporting-section-gap">
            <div class="lh-plugin-card">
                <div class="lh-plugin-card__top">
                    <span class="lh-plugin-card__icon lh-plugin-card__icon--course" aria-hidden="true">
                        <i class="fa fa-users"></i>
                    </span>
                    <div class="lh-plugin-card__meta">
                        <div class="lh-plugin-card__kicker">{{#str}} tile_users_title, local_lernhive_reporting {{/str}}</div>
                        <div class="lh-plugin-card__title">{{selectedcoursename}}</div>
                    </div>
                </div>
                <div class="lh-plugin-card__body">
                    <p class="lh-reporting-kpi">{{usercount}}</p>
                    {{#usersisempty}}
                    <p class="lh-reporting-note">{{#str}} empty_users_in_selected_course, local_lernhive_reporting {{/str}}</p>
                    {{/usersisempty}}
                </div>
                {{#hasselectedcourse}}
                <div class="lh-plugin-card__actions">
                    <a class="lh-plugin-btn lh-plugin-btn--open btn btn-link" href="{{usersdrilldownurl}}">
                        {{#str}} open_users_report, local_lernhive_reporting {{/str}}
                    </a>
                </div>
                {{/hasselectedcourse}}
            </div>

            <div class="lh-plugin-card">
                <div class="lh-plugin-card__top">
                    <span class="lh-plugin-card__icon lh-plugin-card__icon--community" aria-hidden="true">
                        <i class="fa fa-line-chart"></i>
                    </span>
                    <div class="lh-plugin-card__meta">
                        <div class="lh-plugin-card__kicker">{{#str}} tile_popular_title, local_lernhive_reporting {{/str}}</div>
                        <div class="lh-plugin-card__title">{{#str}} top_course_label, local_lernhive_reporting {{/str}}</div>
                    </div>
                </div>
                <div class="lh-plugin-card__body">
                    <p class="lh-reporting-kpi lh-reporting-kpi--title">{{toppopularcoursename}}</p>
                    <p class="lh-reporting-note">{{toppopularcourseusers}} {{#str}} participants_label, local_lernhive_reporting {{/str}}</p>
                </div>
                <div class="lh-plugin-card__actions">
                    <a class="lh-plugin-btn lh-plugin-btn--open btn btn-link" href="{{populardrilldownurl}}">
                        {{#str}} open_popular_report, local_lernhive_reporting {{/str}}
                    </a>
                </div>
            </div>

            <div class="lh-plugin-card">
                <div class="lh-plugin-card__top">
                    <span class="lh-plugin-card__icon lh-plugin-card__icon--tour" aria-hidden="true">
                        <i class="fa fa-check-square-o"></i>
                    </span>
                    <div class="lh-plugin-card__meta">
                        <div class="lh-plugin-card__kicker">{{#str}} tile_completion_title, local_lernhive_reporting {{/str}}</div>
                        <div class="lh-plugin-card__title">{{selectedcoursename}}</div>
                    </div>
                </div>
                <div class="lh-plugin-card__body">
                    <p class="lh-reporting-kpi">{{selectedcompletionratetext}}</p>
                    <p class="lh-reporting-note">
                        {{selectedcompleted}} {{#str}} completed_label, local_lernhive_reporting {{/str}}
                        / {{selectedparticipants}} {{#str}} participants_label, local_lernhive_reporting {{/str}}
                    </p>
                    {{#completionisempty}}
                    <p class="lh-reporting-note">{{#str}} empty_completion_no_participants, local_lernhive_reporting {{/str}}</p>
                    {{/completionisempty}}
                    {{#completionnotstarted}}
                    <p class="lh-reporting-note">{{#str}} empty_completion_no_completions, local_lernhive_reporting {{/str}}</p>
                    {{/completionnotstarted}}
                </div>
                {{#hasselectedcourse}}
                <div class="lh-plugin-card__actions">
                    <a class="lh-plugin-btn lh-plugin-btn--open btn btn-link" href="{{completiondrilldownurl}}">
                        {{#str}} open_completion_report, local_lernhive_reporting {{/str}}
                    </a>
                </div>
                {{/hasselectedcourse}}
            </div>
        </div>

        <div class="lh-plugin-grid lh-plugin-grid--cols-2">
            <div class="lh-plugin-card">
                <div class="lh-plugin-card__top">
                    <span class="lh-plugin-card__icon lh-plugin-card__icon--community" aria-hidden="true">
                        <i class="fa fa-bar-chart"></i>
                    </span>
                    <div class="lh-plugin-card__meta">
                        <div class="lh-plugin-card__kicker">{{#str}} drilldown_popular, local_lernhive_reporting {{/str}}</div>
                        <div class="lh-plugin-card__title">{{#str}} tile_popular_title, local_lernhive_reporting {{/str}}</div>
                    </div>
                </div>
                <div class="lh-plugin-card__body">
                    {{#haspopularrows}}
                    <div class="lh-reporting-table-wrap">
                        <table class="lh-reporting-table">
                            <thead>
                                <tr>
                                    <th>{{#str}} course_label, local_lernhive_reporting {{/str}}</th>
                                    <th class="lh-reporting-cell--num">{{#str}} participants_label, local_lernhive_reporting {{/str}}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#popularrows}}
                                <tr>
                                    <td><a href="{{courseurl}}">{{coursename}}</a></td>
                                    <td class="lh-reporting-cell--num">{{usercount}}</td>
                                </tr>
                                {{/popularrows}}
                            </tbody>
                        </table>
                    </div>
                    {{/haspopularrows}}
                    {{^haspopularrows}}
                    <p class="lh-reporting-empty">{{#str}} no_popular_rows_notice, local_lernhive_reporting {{/str}}</p>
                    {{/haspopularrows}}
                </div>
            </div>

            <div class="lh-plugin-card">
                <div class="lh-plugin-card__top">
                    <span class="lh-plugin-card__icon lh-plugin-card__icon--tour" aria-hidden="true">
                        <i class="fa fa-check"></i>
                    </span>
                    <div class="lh-plugin-card__meta">
                        <div class="lh-plugin-card__kicker">{{#str}} drilldown_completion, local_lernhive_reporting {{/str}}</div>
                        <div class="lh-plugin-card__title">{{#str}} tile_completion_title, local_lernhive_reporting {{/str}}</div>
                    </div>
                </div>
                <div class="lh-plugin-card__body">
                    {{#hascompletionrows}}
                    <div class="lh-reporting-table-wrap">
                        <table class="lh-reporting-table">
                            <thead>
                                <tr>
                                    <th>{{#str}} course_label, local_lernhive_reporting {{/str}}</th>
                                    <th class="lh-reporting-cell--num">{{#str}} participants_label, local_lernhive_reporting {{/str}}</th>
                                    <th class="lh-reporting-cell--num">{{#str}} completed_label, local_lernhive_reporting {{/str}}</th>
                                    <th class="lh-reporting-cell--num">{{#str}} completion_rate_label, local_lernhive_reporting {{/str}}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#completionrows}}
                                <tr>
                                    <td><a href="{{courseurl}}">{{coursename}}</a></td>
                                    <td class="lh-reporting-cell--num">{{participants}}</td>
                                    <td class="lh-reporting-cell--num">{{completed}}</td>
                                    <td class="lh-reporting-cell--num">{{completiontext}}</td>
                                </tr>
                                {{/completionrows}}
                            </tbody>
                        </table>
                    </div>
                    {{/hascompletionrows}}
                    {{^hascompletionrows}}
                    <p class="lh-reporting-empty">{{#str}} no_completion_rows_notice, local_lernhive_reporting {{/str}}</p>
                    {{/hascompletionrows}}
                </div>
            </div>
        </div>
        {{/hascourses}}

        {{^hascourses}}
        <p class="lh-reporting-alert" role="status">
            {{#str}} no_courses_notice, local_lernhive_reporting {{/str}}
        </p>
        {{/hascourses}}
    </div>
</div>
