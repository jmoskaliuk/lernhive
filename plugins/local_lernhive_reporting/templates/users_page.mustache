{{!
    @template local_lernhive_reporting/users_page
}}

<div class="lh-reporting-page">
    <div class="lh-plugin-header">
        <div class="lh-plugin-header__row">
            <a class="lh-plugin-header__nav-btn" href="{{backurl}}">
                <i class="fa fa-arrow-left" aria-hidden="true"></i>
                {{#str}} back_to_dashboard, local_lernhive_reporting {{/str}}
            </a>
            <div class="lh-plugin-header__title-block">
                <div class="lh-plugin-header__name">
                    {{#str}} pluginname, local_lernhive_reporting {{/str}}
                    <span class="lh-plugin-header__sep">|</span>
                    <span class="lh-plugin-header__tagline">{{#str}} tile_users_title, local_lernhive_reporting {{/str}}</span>
                </div>
                <p class="lh-plugin-header__subtitle">{{selectedcoursename}}</p>
            </div>
        </div>
    </div>

    {{#hascourses}}
    <div class="lh-plugin-infobar">
        <div class="lh-plugin-infobar__stats">
            <div class="lh-plugin-infobar__stat">
                <i class="fa fa-book" aria-hidden="true"></i>
                <strong>{{selectedcoursename}}</strong>
            </div>
            <div class="lh-plugin-infobar__stat">
                <i class="fa fa-users" aria-hidden="true"></i>
                <strong>{{rowcount}}</strong>
                {{#str}} participants_label, local_lernhive_reporting {{/str}}
            </div>
        </div>
        {{#hasselectedcourse}}
        <a class="lh-plugin-infobar__cta" href="{{exporturl}}">
            <i class="fa fa-download" aria-hidden="true"></i>
            {{#str}} export_csv, local_lernhive_reporting {{/str}}
        </a>
        {{/hasselectedcourse}}
    </div>
    {{/hascourses}}

    <div class="lh-plugin-content-area">
        {{#hascourses}}
        <div class="lh-plugin-card lh-reporting-filter-card">
            <div class="lh-plugin-card__top">
                <span class="lh-plugin-card__icon lh-plugin-card__icon--generic" aria-hidden="true">
                    <i class="fa fa-filter"></i>
                </span>
                <div class="lh-plugin-card__meta">
                    <div class="lh-plugin-card__kicker">{{#str}} filter_heading, local_lernhive_reporting {{/str}}</div>
                    <div class="lh-plugin-card__title">{{#str}} course_label, local_lernhive_reporting {{/str}}</div>
                </div>
            </div>
            <div class="lh-plugin-card__body">
                <form method="get" action="{{selecturl}}" class="lh-reporting-filter-form">
                    <div class="lh-reporting-field">
                        <label class="lh-reporting-label" for="id_courseid">{{#str}} course_label, local_lernhive_reporting {{/str}}</label>
                        <select id="id_courseid" name="courseid" class="lh-reporting-select">
                            {{#courseoptions}}
                            <option value="{{value}}"{{#selected}} selected{{/selected}}>{{label}}</option>
                            {{/courseoptions}}
                        </select>
                    </div>
                    <button type="submit" class="lh-btn lh-btn--accent btn btn-primary">{{#str}} filter_apply, local_lernhive_reporting {{/str}}</button>
                </form>
            </div>
        </div>

        <div class="lh-plugin-card lh-reporting-section-gap">
            <div class="lh-plugin-card__top">
                <span class="lh-plugin-card__icon lh-plugin-card__icon--course" aria-hidden="true">
                    <i class="fa fa-users"></i>
                </span>
                <div class="lh-plugin-card__meta">
                    <div class="lh-plugin-card__kicker">{{#str}} drilldown_users, local_lernhive_reporting {{/str}}</div>
                    <div class="lh-plugin-card__title">{{selectedcoursename}}</div>
                    <div class="lh-plugin-card__sub">{{#str}} tile_users_title, local_lernhive_reporting {{/str}}</div>
                </div>
            </div>
            <div class="lh-plugin-card__body">
                {{#hasrows}}
                <div class="lh-reporting-table-wrap">
                    <table class="lh-reporting-table">
                        <thead>
                            <tr>
                                <th>{{#str}} name_label, local_lernhive_reporting {{/str}}</th>
                                <th>{{#str}} email_label, local_lernhive_reporting {{/str}}</th>
                                <th>{{#str}} lastaccess_label, local_lernhive_reporting {{/str}}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#rows}}
                            <tr>
                                <td><a href="{{profileurl}}">{{fullname}}</a></td>
                                <td>{{email}}</td>
                                <td>{{lastaccess}}</td>
                            </tr>
                            {{/rows}}
                        </tbody>
                    </table>
                </div>
                {{/hasrows}}
                {{^hasrows}}
                <p class="lh-reporting-empty">{{#str}} no_users_in_course_notice, local_lernhive_reporting {{/str}}</p>
                {{/hasrows}}
            </div>
        </div>
        {{/hascourses}}

        {{^hascourses}}
        <p class="lh-reporting-alert" role="status">{{#str}} no_courses_notice, local_lernhive_reporting {{/str}}</p>
        {{/hascourses}}
    </div>
</div>
