{{> theme_boost/head }}
<body {{{ bodyattributes }}}>
{{> core/local/toast/wrapper}}
<div id="page-wrapper" class="theme-lernhive-shell theme-lernhive-admin-shell">
    {{{ output.standard_top_of_body_html }}}
    <a class="lernhive-skip-link" href="#maincontent">Skip to main content</a>

    <div class="lernhive-app-shell">
        {{> theme_lernhive/sidebar }}

        <div id="page" class="lernhive-page lernhive-admin-page">
            <div class="lernhive-page-header lernhive-admin-header">
                <div class="lernhive-page-header__main">
                    <div class="lernhive-admin-navbar">
                        {{{ output.navbar }}}
                    </div>
                    {{{ output.full_header }}}
                </div>
                <div class="lernhive-page-header__actions">
                    {{{ output.navbar_plugin_output }}}
                    {{{ output.user_menu }}}
                </div>
            </div>

            <div id="page-content" class="lernhive-page-content lernhive-admin-content">
                {{#hasregionmainsettingsmenu}}
                    <div class="lernhive-settings-menu">
                        {{{ regionmainsettingsmenu }}}
                    </div>
                {{/hasregionmainsettingsmenu}}

                {{#hascontenttop}}
                    <section class="lernhive-blocks lernhive-blocks--content-top" data-region="content-top" aria-label="{{#str}} region-content-top, theme_lernhive {{/str}}">
                        {{{ contenttop }}}
                    </section>
                {{/hascontenttop}}

                <main id="region-main-box" class="lernhive-main lernhive-admin-main">
                    <section id="region-main" aria-label="content">
                        <div id="maincontent"></div>
                        {{{ output.course_content_header }}}
                        {{{ output.main_content }}}
                        {{{ output.course_content_footer }}}
                    </section>
                </main>

                {{#hascontentbottom}}
                    <section class="lernhive-blocks lernhive-blocks--content-bottom d-print-none" data-region="content-bottom" aria-label="{{#str}} region-content-bottom, theme_lernhive {{/str}}">
                        {{{ contentbottom }}}
                    </section>
                {{/hascontentbottom}}
            </div>

            {{> theme_lernhive/footer }}
        </div>
    </div>

    {{{ output.standard_after_main_region_html }}}
    {{{ output.standard_end_of_body_html }}}
</div>
</body>
</html>
