{{> theme_boost/head }}
<body {{{ bodyattributes }}}>
{{> core/local/toast/wrapper}}
<div id="page-wrapper" class="theme-lernhive-admin-shell">
    {{{ output.standard_top_of_body_html }}}
    <a class="lernhive-skip-link" href="#maincontent">Skip to main content</a>

    <div id="page" class="container-fluid d-print-block">
        <div id="page-content" class="row d-print-block">
            <div id="region-main-box" class="col-12 {{#hassidepre}}col-lg-9{{/hassidepre}} d-print-block">
                <section id="region-main" class="lernhive-admin-main d-print-block" aria-label="content">
                    <div class="main-inner">
                        <header id="page-header" class="lernhive-admin-header">
                            <div class="lernhive-admin-header__main">
                                {{{ output.full_header }}}
                            </div>
                            <div class="lernhive-admin-header__actions">
                                {{{ output.navbar_plugin_output }}}
                                {{{ output.user_menu }}}
                            </div>
                        </header>

                        {{#hasregionmainsettingsmenu}}
                            <div class="lernhive-settings-menu">
                                {{{ regionmainsettingsmenu }}}
                            </div>
                        {{/hasregionmainsettingsmenu}}

                        {{{ output.course_content_header }}}
                        <div id="maincontent"></div>
                        {{{ output.main_content }}}
                        {{{ output.course_content_footer }}}
                    </div>
                </section>
            </div>

            {{#hassidepre}}
                <aside class="col-12 col-lg-3 lernhive-admin-aside d-print-none" aria-label="Blocks">
                    {{{ sidepreblocks }}}
                </aside>
            {{/hassidepre}}
        </div>
    </div>

    {{{ output.standard_after_main_region_html }}}
    {{{ output.standard_end_of_body_html }}}
</div>
</body>
</html>
