{{!
    Admin layout — LernHive app-shell (sidebar) + Moodle secondary navigation
    (admin settings category tab bar) + main content.

    Structure:
    - LernHive sidebar: consistent top-level nav (Home/Dashboard/MyCourses/SiteAdmin)
    - output.secondary_nav: Moodle admin settings category tabs
      (General | Users | Courses | Grades | Plugins | Server | Reports | …)
    - output.main_content: the actual admin page content (overview, settings forms, etc.)

    No block regions, no Context Dock on admin pages.
}}
{{> theme_boost/head }}
<body {{{ bodyattributes }}}>
{{> core/local/toast/wrapper}}
<div id="page-wrapper" class="theme-lernhive-shell">
    {{{ output.standard_top_of_body_html }}}
    <a class="lernhive-skip-link" href="#maincontent">Skip to main content</a>

    <div class="lernhive-app-shell">
        {{! LernHive sidebar — identical to drawers.mustache }}
        {{> theme_lernhive/sidebar }}

        <div id="page" class="lernhive-page lernhive-admin-page">

            {{! Page header — same structure as drawers layout: title + user actions }}
            <div class="lernhive-page-header">
                <div class="lernhive-page-header__main">
                    {{{ output.full_header }}}
                </div>
                <div class="lernhive-page-header__actions">
                    {{! Header Dock — unified side-panel system (0.9.36). }}
                    {{#hassidepanel}}
                        {{> theme_lernhive/sidepanel }}
                    {{/hassidepanel}}

                    {{#haslangmenu}}
                        <div class="lernhive-lang-menu">
                            {{{ langmenu }}}
                        </div>
                    {{/haslangmenu}}

                    {{#showlauncher}}
                        {{#launcher}}
                            <div class="lernhive-page-header__launcher">
                                {{> theme_lernhive/launcher }}
                            </div>
                        {{/launcher}}
                    {{/showlauncher}}

                    {{! User block: avatar (→ profile) + settings icon + logout icon (0.9.27). }}
                    {{#isloggedin}}
                        <div class="lernhive-user-block">
                            <a href="{{ profileurl }}"
                               class="lernhive-user-block__avatar"
                               title="{{#str}} viewprofile {{/str}}">
                                {{{ useravatar }}}
                            </a>
                            <a href="{{ prefsurl }}"
                               class="lernhive-user-block__action"
                               title="{{#str}} preferences {{/str}}"
                               aria-label="{{#str}} preferences {{/str}}">
                                <i class="fa fa-cog" aria-hidden="true"></i>
                            </a>
                            <a href="{{ logouturl }}"
                               class="lernhive-user-block__action lernhive-user-block__action--danger"
                               title="{{#str}} logout {{/str}}"
                               aria-label="{{#str}} logout {{/str}}">
                                <i class="fa fa-sign-out" aria-hidden="true"></i>
                            </a>
                        </div>
                    {{/isloggedin}}
                </div>
            </div>

            {{! Admin secondary navigation — rendered exactly like Boost's drawers.mustache.
                0.9.34: delegates to Moodle core's moremenu partial so the admin
                sees the canonical Boost admin tab bar (General | Users | Courses |
                Grades | Plugins | Appearance | Server | Reports | Development, …).
                The layout PHP builds `secondarymoremenu` from $PAGE->secondarynav
                via \core\navigation\output\more_menu just like theme_boost does. }}
            {{#secondarymoremenu}}
                <div class="secondary-navigation lernhive-secondary-navigation d-print-none">
                    {{> core/moremenu }}
                </div>
            {{/secondarymoremenu}}
            {{#overflow}}
                <div class="container-fluid tertiary-navigation">
                    <div class="navitem">
                        {{> core/url_select }}
                    </div>
                </div>
            {{/overflow}}

            <div id="page-content" class="lernhive-page-content">
                <main id="region-main-box" class="lernhive-main">
                    <span id="maincontent" class="lernhive-skip-anchor"></span>
                    <div id="region-main">
                        {{! Plugin Shell (0.9.40): /user/preferences.php and
                            any future admin-layout page on the whitelist get a
                            Zone A + Zone B header so they feel like LernHive
                            local plugins. Real Moodle admin settings pages
                            return null from the helper and render unchanged.

                            When the shell is active the core page content is
                            wrapped in .lh-plugin-content-area so the :has()
                            rules in _layout.scss that strip outer padding get
                            compensated by the content-area's own gutter —
                            same trick ContentHub and drawers.mustache use. }}
                        {{#haspluginshell}}
                            {{#pluginshell}}
                                {{> theme_lernhive/plugin_shell_header }}
                            {{/pluginshell}}
                            <div class="lh-plugin-content-area">
                        {{/haspluginshell}}
                        {{#hasregionmainsettingsmenu}}
                            <div class="lernhive-settings-menu">
                                {{{ regionmainsettingsmenu }}}
                            </div>
                        {{/hasregionmainsettingsmenu}}
                        {{{ output.course_content_header }}}
                        {{{ output.main_content }}}
                        {{{ output.activity_navigation }}}
                        {{{ output.course_content_footer }}}
                        {{#haspluginshell}}
                            </div>
                        {{/haspluginshell}}
                    </div>
                </main>
            </div>

            {{> theme_lernhive/footer }}
        </div>
    </div>

    {{{ output.standard_after_main_region_html }}}
    {{{ output.standard_end_of_body_html }}}
</div>
</body>
</html>
{{!
    0.9.42: bootstrap theme_boost/loader so that Aria.tabElementFix() is
    installed and admin secondary-nav tabs become clickable on /admin/search.php.
    Without this require, the [role="tablist"] click handler that calls
    Bootstrap Tab.show() is never registered, and tabs like Users/Courses/Plugins
    don't switch panels. Boost's own drawers.mustache has this same block.
}}
{{#js}}
M.util.js_pending('theme_boost/loader');
require(['theme_boost/loader'], function() {
    M.util.js_complete('theme_boost/loader');
});
{{/js}}
{{!
    0.9.68 hotfix: hard fallback for admin tablists.
    If Boost's delegated tab handler is missing (stale cache / partial JS load),
    links like /admin/search.php#linkgrades should still activate their panel.
}}
{{#js}}
(function() {
    'use strict';

    function resolveTarget(link) {
        var target = link.getAttribute('data-bs-target') || link.getAttribute('data-target') || '';
        if (target && target.charAt(0) === '#') {
            return target;
        }

        var href = link.getAttribute('href') || '';
        var hashindex = href.indexOf('#');
        if (hashindex === -1) {
            return '';
        }

        return href.substring(hashindex);
    }

    function activateTab(link) {
        var target = resolveTarget(link);
        if (!target || target === '#') {
            return;
        }

        var pane = document.querySelector(target);
        if (!pane) {
            return;
        }

        var tablist = link.closest('[role="tablist"]');
        if (tablist) {
            var peers = tablist.querySelectorAll('[data-bs-toggle="tab"], [data-toggle="tab"]');
            for (var i = 0; i < peers.length; i++) {
                peers[i].classList.remove('active');
                peers[i].setAttribute('aria-selected', 'false');
                peers[i].setAttribute('tabindex', '-1');
            }
        }

        var container = pane.parentElement;
        if (container) {
            var panes = container.querySelectorAll('.tab-pane');
            for (var j = 0; j < panes.length; j++) {
                panes[j].classList.remove('active');
                panes[j].classList.remove('show');
            }
        }

        link.classList.add('active');
        link.setAttribute('aria-selected', 'true');
        link.removeAttribute('tabindex');
        pane.classList.add('active');
        pane.classList.add('show');
    }

    function activateFromHash() {
        var hash = window.location.hash || '';
        if (!hash || hash.length < 2) {
            return;
        }

        var links = document.querySelectorAll('[role="tablist"] [data-bs-toggle="tab"], [role="tablist"] [data-toggle="tab"]');
        for (var i = 0; i < links.length; i++) {
            if (resolveTarget(links[i]) === hash) {
                activateTab(links[i]);
                return;
            }
        }
    }

    document.addEventListener('click', function(e) {
        var origin = e.target;
        if (!origin || typeof origin.closest !== 'function') {
            return;
        }

        var link = origin.closest('[role="tablist"] [data-bs-toggle="tab"], [role="tablist"] [data-toggle="tab"]');
        if (!link) {
            return;
        }

        var target = resolveTarget(link);
        if (!target || target === '#') {
            return;
        }

        window.setTimeout(function() {
            var pane = document.querySelector(target);
            if (!pane || pane.classList.contains('active')) {
                return;
            }

            activateTab(link);
        }, 0);
    });

    activateFromHash();
    window.addEventListener('hashchange', activateFromHash);
}());
{{/js}}
