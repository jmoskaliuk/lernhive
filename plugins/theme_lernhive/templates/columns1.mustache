{{> theme_boost/head }}
<body {{{ bodyattributes }}}>
{{> core/local/toast/wrapper}}
<div id="page-wrapper" class="theme-lernhive-popup">
    {{{ output.standard_top_of_body_html }}}
    <a class="lernhive-skip-link" href="#maincontent">Skip to main content</a>

    <main id="page" class="lernhive-popup__page">
        <section class="lernhive-popup__panel">
            <header class="lernhive-popup__header">
                <a href="{{{ config.wwwroot }}}/" class="lernhive-brand__link">{{ sitename }}</a>
            </header>
            <div id="maincontent" class="lernhive-popup__content">
                {{{ output.main_content }}}
            </div>
        </section>
    </main>

    {{{ output.standard_end_of_body_html }}}
</div>
</body>
</html>
