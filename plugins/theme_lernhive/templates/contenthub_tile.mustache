<article class="lernhive-hub-tile">
    {{#tag}}
        <p class="lernhive-hub-tile__tag {{ tagclass }}">{{ tag }}</p>
    {{/tag}}

    <h2 class="lernhive-hub-tile__title">{{ title }}</h2>

    {{#summary}}
        <p class="lernhive-hub-tile__summary">{{ summary }}</p>
    {{/summary}}

    {{#note}}
        <p class="lernhive-hub-tile__note">{{ note }}</p>
    {{/note}}

    {{#primaryactionlabel}}
        <a class="lernhive-hub-tile__cta" href="{{ primaryactionurl }}">
            <span class="lernhive-hub-tile__cta-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                    <path d="M5 12h14"></path>
                    <path d="m12 5 7 7-7 7"></path>
                </svg>
            </span>
            <span>{{ primaryactionlabel }}</span>
        </a>
    {{/primaryactionlabel}}
</article>
