{{!
    Context Dock — floating action strip for Teacher/Trainer and Student actions.
    Rendered only when hasdockitems is truthy (built in drawers.php).
    Context: hasdockitems bool, dockitems[]{key, icon, label, url, active, divider}.
}}
{{#hasdockitems}}
<nav class="lh-dock"
     id="lh-context-dock"
     aria-label="{{#str}} contextdock, theme_lernhive {{/str}}">
    {{#dockitems}}
        {{#divider}}
        <div class="lh-dock__divider" aria-hidden="true"></div>
        {{/divider}}
        <a class="lh-dock__item{{#active}} lh-dock__item--active{{/active}}"
           href="{{{ url }}}"
           aria-label="{{ label }}">
            <span class="lh-dock__icon" aria-hidden="true">
                <i class="fa fa-{{ icon }}"></i>
            </span>
            <span class="lh-dock__tooltip" role="tooltip">{{ label }}</span>
        </a>
    {{/dockitems}}
</nav>
<script>
// Progressive disclosure: hide tooltips after 3 page visits.
// Resets automatically if localStorage is cleared.
(function () {
    var KEY = 'lh_dock_v1';
    var MAX = 3;
    try {
        var n = parseInt(localStorage.getItem(KEY) || '0', 10);
        if (n >= MAX) {
            var dock = document.getElementById('lh-context-dock');
            if (dock) { dock.classList.add('lh-dock--experienced'); }
        } else {
            localStorage.setItem(KEY, String(n + 1));
        }
    } catch (e) { /* storage blocked — tooltips always visible, safe fallback */ }
}());
</script>
{{/hasdockitems}}
