{{> theme_boost/head }}
<body {{{ bodyattributes }}}>
{{> core/local/toast/wrapper}}
<div id="page-wrapper" class="theme-lernhive-shell">
    {{{ output.standard_top_of_body_html }}}
    <a class="lernhive-skip-link" href="#maincontent">Skip to main content</a>

    <div class="lernhive-app-shell">
        {{> theme_lernhive/sidebar }}

        <div id="page" class="lernhive-page lernhive-page--course">
            <header id="page-header" class="lernhive-course-header">
                <div class="lernhive-course-header__main">
                    <div class="lernhive-course-header__eyebrow">{{#str}} courserowlabel, theme_lernhive {{/str}}</div>
                    <div class="lernhive-course-header__content">
                        {{{ output.full_header }}}
                    </div>
                </div>
                <div class="lernhive-course-header__actions">
                    {{{ output.navbar_plugin_output }}}
                    {{{ output.user_menu }}}
                    <div class="lernhive-course-header__utilities" aria-label="{{#str}} courseheadertools, theme_lernhive {{/str}}">
                        <button class="lernhive-course-header__tool" type="button" aria-label="{{#str}} coursedownload, theme_lernhive {{/str}}" title="{{#str}} coursedownload, theme_lernhive {{/str}}">
                            <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                                <path d="M12 3v12"></path>
                                <path d="m7 10 5 5 5-5"></path>
                                <path d="M5 21h14"></path>
                            </svg>
                        </button>
                        <button class="lernhive-course-header__tool" type="button" aria-label="{{#str}} courseprint, theme_lernhive {{/str}}" title="{{#str}} courseprint, theme_lernhive {{/str}}">
                            <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                                <path d="M6 9V4h12v5"></path>
                                <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
                                <path d="M6 14h12v6H6z"></path>
                            </svg>
                        </button>
                        <button class="lernhive-course-header__tool" type="button" aria-label="{{#str}} coursemore, theme_lernhive {{/str}}" title="{{#str}} coursemore, theme_lernhive {{/str}}">
                            <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                                <circle cx="5" cy="12" r="1.7"></circle>
                                <circle cx="12" cy="12" r="1.7"></circle>
                                <circle cx="19" cy="12" r="1.7"></circle>
                            </svg>
                        </button>
                    </div>
                </div>
            </header>

            <div id="page-content" class="lernhive-course-layout">
                <main id="region-main-box" class="lernhive-course-main">
                    {{#hasregionmainsettingsmenu}}
                        <div class="lernhive-settings-menu">
                            {{{ regionmainsettingsmenu }}}
                        </div>
                    {{/hasregionmainsettingsmenu}}

                    <section class="lernhive-course-surface" aria-labelledby="maincontent">
                        <div class="lernhive-course-surface__note">
                            <strong>{{#str}} coursenotetitle, theme_lernhive {{/str}}</strong>
                            <span>{{#str}} coursenotecopy, theme_lernhive {{/str}}</span>
                        </div>

                        <div id="region-main">
                            {{{ output.course_content_header }}}
                            <div id="maincontent"></div>
                            {{{ output.main_content }}}
                            {{{ output.course_content_footer }}}
                        </div>
                    </section>
                </main>

                {{#hassidepre}}
                    <aside class="lernhive-course-aside" aria-label="{{#str}} coursehelpers, theme_lernhive {{/str}}">
                        <div class="lernhive-course-aside__panel">
                            <h2 class="lernhive-course-aside__title">{{#str}} coursehelpertitle, theme_lernhive {{/str}}</h2>
                            <p class="lernhive-course-aside__copy">{{#str}} coursehelpercopy, theme_lernhive {{/str}}</p>
                        </div>
                        <div class="lernhive-course-aside__blocks">
                            {{{ sidepreblocks }}}
                        </div>
                    </aside>
                {{/hassidepre}}
            </div>
        </div>
    </div>

    {{{ output.standard_after_main_region_html }}}
    {{{ output.standard_end_of_body_html }}}
</div>
</body>
</html>
