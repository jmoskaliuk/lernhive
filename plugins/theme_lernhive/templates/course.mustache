{{> theme_boost/head }}
<body {{{ bodyattributes }}}>
{{> core/local/toast/wrapper}}
<div id="page-wrapper" class="theme-lernhive-shell">
    {{{ output.standard_top_of_body_html }}}
    <a class="lernhive-skip-link" href="#maincontent">Skip to main content</a>

    <div class="lernhive-app-shell">
        {{> theme_lernhive/sidebar_course }}

        <div id="page" class="lernhive-page lernhive-page--course">
            {{! Standard LernHive page header — same chrome as drawers.mustache.
                Brings the user block (avatar → profile, prefs, logout), the
                Header Dock (messages, notifications, AI, help), the language
                menu, and the app launcher back to course pages. 0.9.46
                replaces the short-lived bespoke lernhive-course-header card
                that shipped in 0.9.45 and hid all of the above. }}
            {{#showpageheader}}
                <div class="lernhive-page-header{{#hascourseheader}} lernhive-page-header--course{{/hascourseheader}}">
                    {{! Course Plugin Shell Zone A: back ← + course title + category.
                        0.9.58: replaces full_header on real course pages so the
                        header matches the Plugin Shell pattern used by all local
                        plugins. full_header is hidden via CSS on --course pages.
                        Non-course pages (incourse/frontpage) fall back to the old
                        full_header rendering via the {{^hascourseheader}} branch. }}
                    {{#hascourseheader}}
                        {{#courseheader}}
                        <div class="lernhive-course-header">
                            <a href="{{ backurl }}"
                               class="lernhive-course-header__back"
                               aria-label="{{ backlabel }}">
                                <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                                    <polyline points="15 18 9 12 15 6"/>
                                </svg>
                            </a>
                            <div class="lernhive-course-header__title">
                                <h1>{{ coursename }}</h1>
                                {{#hascategoryname}}
                                    <span class="lernhive-course-header__category">
                                        <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                                        {{ categoryname }}
                                    </span>
                                {{/hascategoryname}}
                            </div>
                        </div>
                        {{/courseheader}}
                    {{/hascourseheader}}
                    {{^hascourseheader}}
                        <div class="lernhive-page-header__main">
                            {{{ output.full_header }}}
                        </div>
                    {{/hascourseheader}}
                    <div class="lernhive-page-header__actions">
                        {{#hassidepanel}}
                            {{> theme_lernhive/sidepanel }}
                        {{/hassidepanel}}

                        {{#haslangmenu}}
                            <div class="lernhive-lang-menu">
                                {{{ langmenu }}}
                            </div>
                        {{/haslangmenu}}

                        {{#showlauncher}}
                            {{#launcher}}
                                <div class="lernhive-page-header__launcher">
                                    {{> theme_lernhive/launcher }}
                                </div>
                            {{/launcher}}
                        {{/showlauncher}}

                        {{#isloggedin}}
                            <div class="lernhive-user-block">
                                <a href="{{ profileurl }}"
                                   class="lernhive-user-block__avatar"
                                   title="{{#str}} viewprofile {{/str}}">
                                    {{{ useravatar }}}
                                </a>
                                <a href="{{ prefsurl }}"
                                   class="lernhive-user-block__action"
                                   title="{{#str}} preferences {{/str}}"
                                   aria-label="{{#str}} preferences {{/str}}">
                                    <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                                        <circle cx="12" cy="12" r="3"/>
                                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                                    </svg>
                                </a>
                                <a href="{{ logouturl }}"
                                   class="lernhive-user-block__action lernhive-user-block__action--danger"
                                   title="{{#str}} logout {{/str}}"
                                   aria-label="{{#str}} logout {{/str}}">
                                    <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                                        <polyline points="16 17 21 12 16 7"/>
                                        <line x1="21" y1="12" x2="9" y2="12"/>
                                    </svg>
                                </a>
                            </div>
                        {{/isloggedin}}
                    </div>
                </div>
            {{/showpageheader}}

            <div id="page-content" class="lernhive-course-layout">
                {{#hasregionmainsettingsmenu}}
                    <div class="lernhive-settings-menu">
                        {{{ regionmainsettingsmenu }}}
                    </div>
                {{/hasregionmainsettingsmenu}}

                {{#hascontenttop}}
                    <section class="lernhive-blocks lernhive-blocks--content-top" data-region="content-top" aria-label="{{#str}} region-content-top, theme_lernhive {{/str}}">
                        {{{ contenttop }}}
                    </section>
                {{/hascontenttop}}

                <main id="region-main-box" class="lernhive-course-main">
                    {{! #maincontent must be a SEPARATE empty element (skip-link
                        anchor only). Moodle core CSS gives it height: 1px with
                        overflow: clip, so wrapping real content inside it hides
                        everything. See theme_lernhive session memory. }}
                    <span id="maincontent" class="lernhive-skip-anchor"></span>
                    <section class="lernhive-course-surface" aria-label="content">
                        <div id="region-main">
                            {{{ output.course_content_header }}}
                            {{{ output.main_content }}}
                            {{{ output.course_content_footer }}}
                        </div>
                    </section>
                </main>

                {{#hascontentbottom}}
                    <section class="lernhive-blocks lernhive-blocks--content-bottom" data-region="content-bottom" aria-label="{{#str}} region-content-bottom, theme_lernhive {{/str}}">
                        {{{ contentbottom }}}
                    </section>
                {{/hascontentbottom}}
            </div>

            {{> theme_lernhive/footer }}
        </div>
    </div>

    {{> theme_lernhive/context_dock }}

    {{{ output.standard_after_main_region_html }}}
    {{{ output.standard_end_of_body_html }}}
</div>
</body>
</html>
{{!
    0.9.42: bootstrap theme_boost/loader on course pages so Bootstrap
    tabs, dropdowns, popovers and tooltips all work. Matches the
    require block Boost's upstream layout templates use.
}}
{{#js}}
M.util.js_pending('theme_boost/loader');
require(['theme_boost/loader'], function() {
    M.util.js_complete('theme_boost/loader');
});
{{/js}}
