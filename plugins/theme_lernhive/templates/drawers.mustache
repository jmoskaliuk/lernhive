{{> theme_boost/head }}
<body {{{ bodyattributes }}}>
{{> core/local/toast/wrapper}}
<div id="page-wrapper" class="theme-lernhive-shell">
    {{{ output.standard_top_of_body_html }}}
    <a class="lernhive-skip-link" href="#maincontent">Skip to main content</a>

    <div class="lernhive-app-shell">
        {{> theme_lernhive/sidebar }}

        <div id="page" class="lernhive-page">
            {{#showpageheader}}
                <div class="lernhive-page-header">
                    <div class="lernhive-page-header__main">
                        {{{ output.full_header }}}
                    </div>
                    <div class="lernhive-page-header__actions">
                        {{! Header Dock — unified side-panel system (0.9.36).
                            Replaces core navbar_plugin_output with one shared panel
                            for messages, notifications, AI assistant and help. }}
                        {{#hassidepanel}}
                            {{> theme_lernhive/sidepanel }}
                        {{/hassidepanel}}

                        {{! Language selector — only visible when Moodle has >1 language }}
                        {{#haslangmenu}}
                            <div class="lernhive-lang-menu">
                                {{{ langmenu }}}
                            </div>
                        {{/haslangmenu}}

                        {{! App Launcher — grid-dots icon, opens plugin launcher dropdown }}
                        {{#showlauncher}}
                            {{#launcher}}
                                <div class="lernhive-page-header__launcher">
                                    {{> theme_lernhive/launcher }}
                                </div>
                            {{/launcher}}
                        {{/showlauncher}}

                        {{! User block: avatar (→ profile) + settings icon + logout icon.
                            Dropdown removed (0.9.27): actions are always-visible icon buttons. }}
                        {{#isloggedin}}
                            <div class="lernhive-user-block">
                                <a href="{{ profileurl }}"
                                   class="lernhive-user-block__avatar"
                                   title="{{#str}} viewprofile {{/str}}">
                                    {{{ useravatar }}}
                                </a>
                                <a href="{{ prefsurl }}"
                                   class="lernhive-user-block__action"
                                   title="{{#str}} preferences {{/str}}"
                                   aria-label="{{#str}} preferences {{/str}}">
                                    {{! Lucide "settings" — matches sidepanel icon weight }}
                                    <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                                        <circle cx="12" cy="12" r="3"/>
                                        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                                    </svg>
                                </a>
                                <a href="{{ logouturl }}"
                                   class="lernhive-user-block__action lernhive-user-block__action--danger"
                                   title="{{#str}} logout {{/str}}"
                                   aria-label="{{#str}} logout {{/str}}">
                                    {{! Lucide "log-out" — matches sidepanel icon weight }}
                                    <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                                        <polyline points="16 17 21 12 16 7"/>
                                        <line x1="21" y1="12" x2="9" y2="12"/>
                                    </svg>
                                </a>
                            </div>
                        {{/isloggedin}}
                    </div>
                </div>
            {{/showpageheader}}

            <div id="page-content" class="lernhive-page-content">
                {{#hasregionmainsettingsmenu}}
                    <div class="lernhive-settings-menu">
                        {{{ regionmainsettingsmenu }}}
                    </div>
                {{/hasregionmainsettingsmenu}}

                {{#hascontenttop}}
                    <section class="lernhive-blocks lernhive-blocks--content-top" data-region="content-top" aria-label="{{#str}} region-content-top, theme_lernhive {{/str}}">
                        {{{ contenttop }}}
                    </section>
                {{/hascontenttop}}

                {{! output.main_content must be called here in Mustache — calling
                    $OUTPUT->main_content() in the PHP layout file runs before the page
                    content is buffered and returns empty. Mustache renders at the right time. }}
                <main id="region-main-box" class="lernhive-main">
                    {{! #maincontent MUST be a separate empty element — never the content
                        wrapper. Moodle core CSS (Boost) sets:
                            #maincontent { height: 1px; overflow: clip; }
                        to use this as a skip-link anchor only. Putting real content inside
                        it makes everything invisible. See session memory "hard-won knowledge". }}
                    <span id="maincontent" class="lernhive-skip-anchor"></span>
                    <section class="lernhive-main-section" aria-label="content">
                        <div id="region-main">
                        {{! Plugin Shell (0.9.40): core Moodle pages like /my/,
                            /my/courses.php and /user/profile.php get a Zone A +
                            Zone B header injected here so they look like the
                            LernHive local plugins. Local plugins that already
                            render their own Plugin Shell inside main_content
                            (ContentHub, Copy, …) are excluded by the helper
                            and therefore never render a duplicate header.

                            When the shell is active the core page content is
                            wrapped in .lh-plugin-content-area so the :has()
                            rules in _layout.scss that strip outer padding get
                            compensated by the content-area's own gutter — same
                            trick ContentHub uses. }}
                        {{#haspluginshell}}
                            {{#pluginshell}}
                                {{> theme_lernhive/plugin_shell_header }}
                            {{/pluginshell}}
                            <div class="lh-plugin-content-area">
                        {{/haspluginshell}}
                        {{{ output.course_content_header }}}
                        {{{ output.main_content }}}
                        {{{ output.course_content_footer }}}
                        {{#haspluginshell}}
                            </div>
                        {{/haspluginshell}}
                        </div>
                    </section>
                </main>

                {{#hascontentbottom}}
                    <section class="lernhive-blocks lernhive-blocks--content-bottom" data-region="content-bottom" aria-label="{{#str}} region-content-bottom, theme_lernhive {{/str}}">
                        {{{ contentbottom }}}
                    </section>
                {{/hascontentbottom}}
            </div>

            {{> theme_lernhive/footer }}
        </div>
    </div>

    {{> theme_lernhive/context_dock }}

    {{{ output.standard_after_main_region_html }}}
    {{{ output.standard_end_of_body_html }}}
</div>
</body>
</html>
{{!
    0.9.42: bootstrap theme_boost/loader so Aria fixes, tab remembering,
    popovers, tooltips, dropdown keyboard nav and collapse interactions all
    work across drawer-based pages. Boost's upstream drawers.mustache has
    this same require block — we were missing it entirely.
}}
{{#js}}
M.util.js_pending('theme_boost/loader');
require(['theme_boost/loader'], function() {
    M.util.js_complete('theme_boost/loader');
});
{{/js}}
