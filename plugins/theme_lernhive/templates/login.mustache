{{> theme_boost/head }}
<body {{{ bodyattributes }}}>
{{> core/local/toast/wrapper}}
<div id="page-wrapper" class="theme-lernhive-login">
    {{{ output.standard_top_of_body_html }}}
    <a class="lernhive-skip-link" href="#maincontent">Skip to main content</a>

    <main id="page" class="lernhive-login__page">
        {{! #maincontent is Moodle's skip-link target — core CSS forces it to
            height:1px; overflow:clip. Never put real content inside it. }}
        <div id="maincontent" tabindex="-1" aria-hidden="true"></div>
        <section class="lernhive-login__panel">
            {{! Brand is already rendered inside Moodle's login form content — no duplicate here. }}
            <div class="lernhive-login__content">
                {{{ output.main_content }}}
            </div>
        </section>
    </main>

    {{! Floating privacy / cookies button — bottom-right corner.
        Replaces the Moodle-rendered "Cookies notice" button which sits inside
        the login card. The original is hidden via CSS in _login.scss. }}
    <a href="{{{ config.wwwroot }}}/admin/tool/policy/index.php"
       class="lernhive-privacy-fab"
       aria-label="{{#str}} privacy, theme_lernhive {{/str}}"
       title="{{#str}} privacy, theme_lernhive {{/str}}">
        {{! Lucide "shield" icon }}
        <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
    </a>

    {{{ output.standard_end_of_body_html }}}
</div>
</body>
</html>
