{{!
    @template  theme_lernhive/plugin_shell_header

    Shared Plugin Shell Zone A + Zone B header (0.9.40).

    Used by:
    - theme_lernhive drawers.mustache / admin.mustache — injected into
      core Moodle pages (Dashboard, My courses, Profile, Preferences)
      via `theme_lernhive_get_plugin_shell_context($PAGE)`.
    - local LernHive plugins that want to reuse the same markup instead
      of hand-rolling Zone A + Zone B (see local_lernhive_onboarding).

    The markup mirrors `local_lernhive_contenthub/templates/hub_page.mustache`
    one-to-one — the two must stay visually identical.  When Zone B has
    no work to do (pure navigation pages) pass `hint` as the only field;
    the template falls back to a single `<i class="fa fa-info-circle">`
    hint line just like ContentHub's infobar row.

    Context variables required for this template:
    * name        (string) - Plugin / area name shown bold in Zone A (e.g. "Dashboard")
    * tagline     (string) - Short tagline shown after the `|` separator
    * subtitle    (string) - One-sentence description below the name line
    * hint        (string) - Zone B info hint row (rendered when `hasprogress` is falsy)
    * tags        (array)  - Optional list of tag pills { modifier, faicon, label }
    * hastags     (bool)   - Whether the tag row should render
    * hasprogress (bool)   - When true, Zone B renders a progress bar instead of the hint row
    * progress    (object) - Progress bar data (only read when `hasprogress` is true):
                              - label   (string) e.g. "Overall progress"
                              - percent (int)    0-100
                              - count   (string) e.g. "5 of 12 tours"

    Example context (json):
    {
        "name":     "Dashboard",
        "tagline":  "Overview",
        "subtitle": "Your learning progress, courses, and quick actions.",
        "hint":     "Pick up where you left off, or explore new content below.",
        "hastags":  true,
        "tags": [
            { "modifier": "type", "faicon": "fa-home", "label": "Overview" }
        ],
        "hasprogress": false,
        "progress": {
            "label":   "Overall progress",
            "percent": 42,
            "count":   "5 of 12 tours"
        }
    }
}}
{{! ── Zone A: sticky page header ─────────────────────────────────────────── }}
<div class="lh-plugin-header">
    <div class="lh-plugin-header__row">
        <div class="lh-plugin-header__title-block">
            <div class="lh-plugin-header__name">
                {{ name }}
                <span class="lh-plugin-header__sep" aria-hidden="true">|</span>
                <span class="lh-plugin-header__tagline">{{ tagline }}</span>
            </div>
            <p class="lh-plugin-header__subtitle">{{ subtitle }}</p>
            {{#hastags}}
                <div class="lh-plugin-header__tags" aria-label="{{#str}} tags {{/str}}">
                    {{#tags}}
                        <span class="lh-plugin-tag lh-plugin-tag--{{ modifier }}">
                            <i class="fa {{ faicon }}" aria-hidden="true"></i>
                            {{ label }}
                        </span>
                    {{/tags}}
                </div>
            {{/hastags}}
        </div>
    </div>
</div>

{{! ── Zone B: info bar ───────────────────────────────────────────────────── }}
<div class="lh-plugin-infobar">
    {{#hasprogress}}
        {{#progress}}
        <div class="lh-plugin-infobar__progress">
            <span class="lh-plugin-infobar__progress-label">{{ label }}</span>
            <div class="lh-plugin-infobar__progress-track">
                <div class="lh-plugin-infobar__progress-fill"
                     role="progressbar"
                     style="width: {{ percent }}%"
                     aria-valuenow="{{ percent }}"
                     aria-valuemin="0"
                     aria-valuemax="100"></div>
            </div>
            <span class="lh-plugin-infobar__progress-count">{{ percent }}%</span>
            <span class="lh-plugin-infobar__progress-count lh-plugin-infobar__progress-count--muted">{{ count }}</span>
        </div>
        {{/progress}}
    {{/hasprogress}}
    {{^hasprogress}}
        <div class="lh-plugin-infobar__stats">
            <span class="lh-plugin-infobar__stat">
                <i class="fa fa-info-circle" aria-hidden="true"></i>
                {{ hint }}
            </span>
        </div>
    {{/hasprogress}}
</div>
