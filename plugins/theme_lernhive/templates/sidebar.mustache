<aside class="lernhive-sidebar">
    <div class="lernhive-brand">
        <a href="{{{ config.wwwroot }}}/" class="lernhive-brand__link">{{ sitename }}</a>
        <p class="lernhive-brand__meta">{{#str}} exploreoptional, theme_lernhive {{/str}}</p>
    </div>

    {{! User bar: user menu + launcher trigger side by side. }}
    <div class="lernhive-sidebar__user-bar">
        <div class="lernhive-sidebar__user-info">
            {{{ output.user_menu }}}
        </div>
        {{#showlauncher}}
            {{#launcher}}
                {{> theme_lernhive/launcher }}
            {{/launcher}}
        {{/showlauncher}}
    </div>

    {{! Primary navigation — rendered directly so Moodle's nav tree is
        fully initialised at render time. output.primary_nav is stable in
        Moodle 5.x (unlike the removed flat_navigation). }}
    <nav class="lernhive-nav" aria-label="{{#str}} primarynavigation, theme_lernhive {{/str}}">
        {{{ output.primary_nav }}}
    </nav>

    {{#hassidebarbottom}}
        <div class="lernhive-sidebar__blocks" data-region="sidebar-bottom" aria-label="{{#str}} region-sidebar-bottom, theme_lernhive {{/str}}">
            {{{ sidebarbottom }}}
        </div>
    {{/hassidebarbottom}}

    <div class="lernhive-sidebar__notes">
        <p class="lernhive-sidebar__note"><strong>{{#str}} flavourpriority, theme_lernhive {{/str}}</strong></p>
        <p class="lernhive-sidebar__note">{{#str}} flavourprioritydesc, theme_lernhive {{/str}}</p>
    </div>
</aside>
