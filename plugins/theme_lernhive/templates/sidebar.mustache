<aside class="lernhive-sidebar">
    <div class="lernhive-brand">
        <a href="{{{ config.wwwroot }}}/" class="lernhive-brand__link" aria-label="LernHive — Home">
            <img src="{{{ config.wwwroot }}}/theme/lernhive/pix/logo-sidebar.svg"
                 alt="LernHive"
                 class="lernhive-brand__logo"
                 width="148"
                 height="30">
        </a>
    </div>

    {{! Primary navigation — built manually in PHP as $navitems array with
        FontAwesome icons, passed via template context. output.primary_nav
        returned empty in Moodle 5.x in this layout context. }}
    <nav class="lernhive-nav" aria-label="{{#str}} primarynavigation, theme_lernhive {{/str}}">
        <ul class="lernhive-nav__list">
            {{#navitems}}
            <li class="lernhive-nav__item">
                <a class="lernhive-nav__link{{#isactive}} lernhive-nav__link--active{{/isactive}}"
                   href="{{ url }}"{{#isactive}} aria-current="page"{{/isactive}}>
                    <i class="fa fa-{{ faicon }}" aria-hidden="true"></i>
                    <span class="lernhive-nav__text">{{ text }}</span>
                </a>
            </li>
            {{/navitems}}
        </ul>
    </nav>

    {{#hassidebarbottom}}
        <div class="lernhive-sidebar__blocks" data-region="sidebar-bottom" aria-label="{{#str}} region-sidebar-bottom, theme_lernhive {{/str}}">
            {{{ sidebarbottom }}}
        </div>
    {{/hassidebarbottom}}

    <div class="lernhive-sidebar__notes">
        <p class="lernhive-sidebar__note"><strong>{{#str}} flavourpriority, theme_lernhive {{/str}}</strong></p>
        <p class="lernhive-sidebar__note">{{#str}} flavourprioritydesc, theme_lernhive {{/str}}</p>
    </div>
</aside>
