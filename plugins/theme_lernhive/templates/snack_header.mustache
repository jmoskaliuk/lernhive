<header class="lernhive-snack-header" aria-labelledby="lernhive-snack-title">
    {{#eyebrow}}
        <p class="lernhive-snack-header__eyebrow">{{ eyebrow }}</p>
    {{/eyebrow}}

    <div class="lernhive-snack-header__head">
        <div class="lernhive-snack-header__main">
            <h1 id="lernhive-snack-title" class="lernhive-snack-header__title">{{ title }}</h1>
            {{#summary}}
                <p class="lernhive-snack-header__summary">{{ summary }}</p>
            {{/summary}}
        </div>

        <div class="lernhive-snack-header__actions">
            {{#duration}}
                <span class="lernhive-snack-header__pill">{{ duration }}</span>
            {{/duration}}
            {{#steps}}
                <span class="lernhive-snack-header__pill">{{ steps }}</span>
            {{/steps}}
            {{#follow}}
                <button class="lernhive-snack-header__pill is-follow" type="button" aria-label="{{#str}} follow, theme_lernhive {{/str}}">
                    <span class="lernhive-snack-header__pill-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" focusable="false">
                            <path d="m12 3 2.8 5.7 6.2.9-4.5 4.4 1 6.2L12 17.3 6.5 20.2l1-6.2L3 9.6l6.2-.9z"></path>
                        </svg>
                    </span>
                    <span>{{#str}} follow, theme_lernhive {{/str}}</span>
                </button>
            {{/follow}}
            {{#bookmark}}
                <button class="lernhive-snack-header__pill" type="button" aria-label="{{#str}} bookmark, theme_lernhive {{/str}}">
                    <span class="lernhive-snack-header__pill-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" focusable="false">
                            <path d="M19 21 12 16 5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path>
                        </svg>
                    </span>
                    <span>{{#str}} bookmark, theme_lernhive {{/str}}</span>
                </button>
            {{/bookmark}}

            <div class="lernhive-snack-header__tools" aria-label="{{#str}} snacktools, theme_lernhive {{/str}}">
                <button class="lernhive-snack-header__tool" type="button" aria-label="{{#str}} snackdownload, theme_lernhive {{/str}}" title="{{#str}} snackdownload, theme_lernhive {{/str}}">
                    <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                        <path d="M12 3v12"></path>
                        <path d="m7 10 5 5 5-5"></path>
                        <path d="M5 21h14"></path>
                    </svg>
                </button>
                <button class="lernhive-snack-header__tool" type="button" aria-label="{{#str}} snackprint, theme_lernhive {{/str}}" title="{{#str}} snackprint, theme_lernhive {{/str}}">
                    <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                        <path d="M6 9V4h12v5"></path>
                        <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
                        <path d="M6 14h12v6H6z"></path>
                    </svg>
                </button>
                <button class="lernhive-snack-header__tool" type="button" aria-label="{{#str}} snackmore, theme_lernhive {{/str}}" title="{{#str}} snackmore, theme_lernhive {{/str}}">
                    <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                        <circle cx="5" cy="12" r="1.7"></circle>
                        <circle cx="12" cy="12" r="1.7"></circle>
                        <circle cx="19" cy="12" r="1.7"></circle>
                    </svg>
                </button>
            </div>
        </div>
    </div>
</header>
